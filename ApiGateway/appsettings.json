{
  "Keycloak": {
    "Url": "http://localhost:8080",
    "Realm": "IdeaFusion",
    "Audience": "ideafusion_api"
  },
  "Gateway": {
    "MaxRequestSize": 104857600,
    "DefaultRateLimit": {
      "RequestsPerMinute": 100,
      "Burst": 20
    }
  },
  "ReverseProxy": {
    "Routes": {

      "aggregator-root-route": {
        "ClusterId": "aggregator-cluster",
        "Match": { "Path": "/api/aggregator" },
        "Order": 1,
        "Metadata": { "ServiceName": "aggregator", "RateLimit:RequestsPerMinute": "80", "RateLimit:Burst": "20" },
        "Transforms": []
      },
      "aggregator-route": {
        "ClusterId": "aggregator-cluster",
        "Match": { "Path": "/api/aggregator/{**catch-all}" },
        "Order": 2,
        "Metadata": { "ServiceName": "aggregator", "RateLimit:RequestsPerMinute": "80", "RateLimit:Burst": "20" },
        "Transforms": []
      },

      "content-posts-root-route": {
