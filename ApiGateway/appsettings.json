        "Metadata": { "ServiceName": "contentservice" },
        "Transforms": []
      },
      "content-tags-route": {
        "ClusterId": "content-cluster",
        "Match": { "Path": "/api/tag/{**catch-all}" },
        "Order": 6,
        "Metadata": { "ServiceName": "contentservice", "RateLimit:RequestsPerMinute": "120", "RateLimit:Burst": "20" },
        "Transforms": []
      },
      "content-collaborationsnapshot-route": {
