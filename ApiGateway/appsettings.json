{
  "Keycloak": {
    "Url": "http://localhost:8080",
    "Realm": "IdeaFusion",
    "Audience": "ideafusion_api"
  },
  "Gateway": {
    "MaxRequestSize": 5242880,
    "DefaultRateLimit": {
      "RequestsPerMinute": 100,
      "Burst": 20
    }
  },
  "ReverseProxy": {
    "Routes": {
      "aggregator-root-route": {
        "ClusterId": "aggregator-cluster",
        "Match": {
          "Path": "/api/aggregator"
        },
        "Order": 1,
        "Metadata": {
          "ServiceName": "aggregator",
          "Version": "v1",
          "Team": "platform",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "80",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        },
        "Transforms": []
      },
      "aggregator-route": {
        "ClusterId": "aggregator-cluster",
        "Match": {
          "Path": "/api/aggregator/{**catch-all}"
        },
        "Order": 2,
        "Metadata": {
          "ServiceName": "aggregator",
          "Version": "v1",
          "Team": "platform",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "80",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        },
        "Transforms": []
      },
      "content-posts-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/post/{**catch-all}"
        },
        "Order": 3,
        "Metadata": {
          "ServiceName": "contentservice",
          "Version": "v1",
          "Team": "content",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "120",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        },
        "Transforms": []
      },
      "content-comments-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/comment/{**catch-all}"
        },
        "Order": 4,
        "Metadata": {
          "ServiceName": "contentservice",
          "Version": "v1",
          "Team": "content",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "120",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        },
        "Transforms": []
      },
      "content-interactions-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/interactions/{**catch-all}"
        },
        "Order": 5,
        "Metadata": {
          "ServiceName": "contentservice",
          "Version": "v1",
          "Team": "content",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "120",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        },
        "Transforms": []
      },
      "content-tags-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/tag/{**catch-all}"
        },
        "Order": 6,
        "Metadata": {
          "ServiceName": "contentservice",
          "Version": "v1",
          "Team": "content",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "120",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        },
        "Transforms": []
      },
      "content-collaborationsnapshot-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/collaborationSnapshot/{**catch-all}"
        },
        "Order": 7,
        "Metadata": {
          "ServiceName": "contentservice",
          "Version": "v1",
          "Team": "content",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "120",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        },
        "Transforms": []
      },
      "collaboration-route": {
        "ClusterId": "collaboration-cluster",
        "Match": {
          "Path": "/api/collaboration/{**catch-all}"
        },
        "Order": 8,
        "Metadata": {
          "ServiceName": "collaborationservice",
          "Version": "v1",
          "Team": "collaborations",
          "Priority": "high",
          "RateLimit:RequestsPerMinute": "60",
          "RateLimit:Burst": "10",
          "SessionAffinity": "true"
      },
      "Transforms": []
    },
    "collaboration-posts-route": {
      "ClusterId": "collaboration-cluster",
      "Match": {
        "Path": "/api/team-post/{**catch-all}"
      },
      "Order": 9,
      "Metadata": {
        "ServiceName": "collaborationservice",
        "Version": "v1",
        "Team": "collaborations",
        "Priority": "high",
        "RateLimit:RequestsPerMinute": "60",
        "RateLimit:Burst": "10",
        "SessionAffinity": "true"
      
    },
    "Transforms": []
  },
  "collaboration-requests-route": {
    "ClusterId": "collaboration-cluster",
    "Match": {
      "Path": "/api/collaboration-request/{**catch-all}"
    },
    "Order": 10,
    "Metadata": {
      "ServiceName": "collaborationservice",
      "Version": "v1",
      "Team": "collaborations",
      "Priority": "high",
      "RateLimit:RequestsPerMinute": "60",
      "RateLimit:Burst": "10",
      "SessionAffinity": "true"
    },
  "Transforms": []
  },
  "collaboration-invitations-route": {
    "ClusterId": "collaboration-cluster",
    "Match": {
      "Path": "/api/collaboration-invitation/{**catch-all}"
    },
    "Order": 11,
    "Metadata": {
      "ServiceName": "collaborationservice",
      "Version": "v1",
      "Team": "collaborations",
      "Priority": "high",
      "RateLimit:RequestsPerMinute": "60",
      "RateLimit:Burst": "10",
      "SessionAffinity": "true"
    },
    "Transforms": []
  },
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Metadata": {
          "ServiceName": "identityservice-api",
          "RateLimit:RequestsPerMinute": "100",
          "RateLimit:Burst": "20",
          "SessionAffinity": "false"
        }
      },
      "identity-users-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" },
        "Metadata": {
          "ServiceName": "identityservice-api",
          "RateLimit:RequestsPerMinute": "60",
          "RateLimit:Burst": "10",
          "SessionAffinity": "false"
        }
      }
    },
    
    "Clusters": {
      "aggregator-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "SessionAffinity": {
          "Enabled": false
        },
        "HttpRequest": {
          "ActivityTimeout": "00:01:00",
          "MaxRequestBodySize": 5242880
        },
        "Destinations": {
          "aggregator-destination": {
            "Address": "http://aggregator"
          }
        }
      },

      "content-cluster": {
        "LoadBalancingPolicy": "LeastRequests",
        "SessionAffinity": {
          "Enabled": false
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30",
          "MaxRequestBodySize": 5242880
        },
        "Destinations": {
          "content-destination": {
            "Address": "http://contentservice"
          }
        }
      },

      "collaboration-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "SessionAffinity": {
          "Enabled": false
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30",
          "MaxRequestBodySize": 5242880
        },
        "Destinations": {
          "collaboration-destination": {
            "Address": "http://collaborationservice"
          }
        }
      },
      "identity-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": { "ActivityTimeout": "00:00:30" },
        "Metadata": { "ServiceName": "identityservice-api" },
        "Destinations": {
          "identity-destination": {
            "Address": "http://identityservice-api"
          }
        }
      }
    }
  }
}