        "Transforms": []
      }
    },

    "Clusters": {
      "aggregator-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "SessionAffinity": { "Enabled": false },
        "HttpRequest": { "ActivityTimeout": "00:01:00", "MaxRequestBodySize": 5242880 },
        "Destinations": {
          "aggregator-destination": { "Address": "http://aggregator" }
        }
      },
      "content-cluster": {
        "LoadBalancingPolicy": "LeastRequests",
        "SessionAffinity": { "Enabled": false },
        "HttpRequest": { "ActivityTimeout": "00:00:30", "MaxRequestBodySize": 52428800 },
        "Destinations": {
          "content-destination": { "Address": "http://contentservice" }
        }
      },
      "collaboration-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "SessionAffinity": { "Enabled": false },
        "HttpRequest": { "ActivityTimeout": "00:00:30", "MaxRequestBodySize": 5242880 },
        "Destinations": {
          "collaboration-destination": { "Address": "http://collaborationservice" }
        }
      },
      "identity-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HttpRequest": { "ActivityTimeout": "00:00:30" },
        "Destinations": {
          "identity-destination": { "Address": "http://identityservice" }
        }
      }
    }
